# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI / Codex
# OPENAI_API_KEY=sk-xxx

# AWS Bedrock
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Atomics configuration
# Linux default: ~/.local/share/atomics/atomics.db (XDG)
# macOS default: data/atomics.db (project-local)
ATOMICS_DB_PATH=data/atomics.db
ATOMICS_LOG_LEVEL=INFO
ATOMICS_DEFAULT_MODEL=claude-sonnet-4-6
ATOMICS_MAX_TOKENS_PER_HOUR=100000
ATOMICS_MAX_REQUESTS_PER_MINUTE=30
ATOMICS_LOOP_INTERVAL_SECONDS=120
ATOMICS_BUDGET_LIMIT_USD=50.00
